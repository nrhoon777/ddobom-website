rules_version = '2';
// 또봄 관리자 콘솔 보안 규칙
// Firebase 콘솔 → Firestore Database → 규칙(Rules) 탭에 아래 내용을 붙여넣고 게시(Publish)하세요.
service cloud.firestore {
  match /databases/{database}/documents {

    // 로그인 사용자의 이메일(소문자)로 roles 문서를 찾음
    function roleDoc() {
      return get(/databases/$(database)/documents/roles/$(request.auth.token.email.lower()));
    }
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/roles/$(request.auth.token.email.lower()))
        && roleDoc().data.active != false;
    }
    function isEditor() {
      return isAdmin() && (roleDoc().data.role == 'owner' || roleDoc().data.role == 'editor');
    }
    function isOwner() {
      return isAdmin() && roleDoc().data.role == 'owner';
    }

    // 게시글: 공개글은 누구나 읽기, 그 외/쓰기는 운영진
    match /posts/{postId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isEditor();
    }

    // 권한: 운영진만 조회, 최고관리자만 변경
    match /roles/{email} {
      allow read: if isAdmin();
      allow write: if isOwner();
    }
  }
}
